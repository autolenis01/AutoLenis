# =============================================================================
# AutoLenis Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# --- App Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_ENV_BADGE=development
# NOTE: Mock/test mode is controlled server-side via workspace membership,
#       NOT via environment variables. See lib/app-mode.ts → isTestWorkspace().
ADMIN_SUBDOMAIN_ENABLED=false

# --- Authentication (JWT) ---
# Required: Generate with `openssl rand -base64 32`
JWT_SECRET=your-jwt-secret-change-in-production

# Optional: Set to allow first admin account creation via /api/admin/auth/signup
# Remove after first admin is created
# ADMIN_BOOTSTRAP_SECRET=your-bootstrap-secret

# --- Admin Setup Script (scripts/create-admin-user.mjs) ---
# Set these to create the initial super admin account
# SUPER_ADMIN_EMAIL=your-admin@example.com
# SUPER_ADMIN_TEMP_PASSWORD=your-secure-temp-password

# --- NextAuth (if using NextAuth routes) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production

# --- Supabase ---
# Required: Get from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_URL=https://your-project.supabase.co
# JWT secret for verifying Supabase-issued JWTs (Settings → API → JWT Settings)
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Supabase (Development redirect) ---
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# --- Database (Prisma) ---
# Required: PostgreSQL connection strings from Supabase → Settings → Database
# Pooled connection (port 6543, via PgBouncer) — used by Prisma for queries
POSTGRES_PRISMA_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
# Non-pooling connection (port 5432, direct) — used by Prisma for migrations
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/postgres
# General-purpose pooled URL — used by migration scripts
POSTGRES_URL=postgresql://user:password@host:6543/postgres

# --- Redis (Distributed Rate Limiting) ---
# Required in production for distributed rate limiting of login/MFA auth flows.
# Without Redis, admin login/MFA rate limiting fails closed in production,
# and middleware auth rate limiting returns 503.
# Admin sessions are database-backed (AdminSession table) and do NOT require Redis.
# In development/test, in-memory fallback is used automatically.
# Example: redis://default:password@your-redis-host:6379
# REDIS_URL=

# --- Stripe ---
# Required for payments: Get from Stripe dashboard
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# --- Email (Resend only — ALL emails are sent LIVE, no mocks) ---
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@autolenis.com
FROM_NAME=AutoLenis
ADMIN_NOTIFICATION_EMAIL=info@autolenis.com
# DEV_EMAIL_TO overrides all recipients in non-production so real users
# never receive dev traffic while emails still send LIVE through Resend.
# Recommended for local development.
DEV_EMAIL_TO=dev-testing@autolenis.com

# --- Cron / Webhooks ---
CRON_SECRET=your-cron-secret
ESIGN_WEBHOOK_SECRET=your-esign-webhook-secret
INTERNAL_API_KEY=your-internal-api-key

# --- DocuSign (Optional — required for dealer agreement signing) ---
DOCUSIGN_INTEGRATION_KEY=your-docusign-integration-key
DOCUSIGN_USER_ID=your-docusign-user-id
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
DOCUSIGN_PRIVATE_KEY_BASE64=base64-encoded-rsa-private-key
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_SECRET_KEY=your-docusign-secret-key
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_OAUTH_BASE_URL=https://account-d.docusign.com
DOCUSIGN_DEALER_TEMPLATE_ID=your-dealer-agreement-template-id
DOCUSIGN_WEBHOOK_SECRET=your-docusign-webhook-hmac-secret
DOCUSIGN_CONNECT_SECRET=your-docusign-connect-hmac-secret
DOCUSIGN_RETURN_URL=https://www.autolenis.com/dealer/onboarding/agreement/success
DOCUSIGN_BRAND_ID=
DOCUSIGN_ENV=sandbox

# --- Monitoring (Optional) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Third-party Integrations (Optional) ---
OPENROAD_PARTNER_ID=

# --- AI / Gemini ---
# Required for AI assistant: Get from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Optional: Override the default Gemini model
# GEMINI_MODEL=gemini-pro
# Set to "true" to disable all AI actions (kill switch)
# AI_ACTIONS_DISABLED=false

# --- Database (Direct URL for migrations) ---
# Used by migration scripts when a non-pooling connection is required
# SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname
