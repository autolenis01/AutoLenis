// AutoLenis Database Schema
// Complete schema for all 13 systems

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================
// WORKSPACE / TENANT ISOLATION
// ============================================

enum WorkspaceMode {
  LIVE
  TEST
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  mode      WorkspaceMode @default(LIVE)
  createdAt DateTime      @default(now())
  createdBy String?

  // Relations
  users                          User[]
  buyerProfiles                  BuyerProfile[]
  dealers                        Dealer[]
  dealerUsers                    DealerUser[]
  adminUsers                     AdminUser[]
  affiliates                     Affiliate[]
  preQualifications              PreQualification[]
  buyerPreferences               BuyerPreferences[]
  inventoryItems                 InventoryItem[]
  shortlists                     Shortlist[]
  auctions                       Auction[]
  auctionParticipants            AuctionParticipant[]
  auctionOffers                  AuctionOffer[]
  bestPriceOptions               BestPriceOption[]
  selectedDeals                  SelectedDeal[]
  financingOffers                FinancingOffer[]
  externalPreApprovals           ExternalPreApproval[]
  insuranceQuotes                InsuranceQuote[]
  insurancePolicies              InsurancePolicy[]
  contractDocuments              ContractDocument[]
  contractShieldScans            ContractShieldScan[]
  eSignEnvelopes                 ESignEnvelope[]
  pickupAppointments             PickupAppointment[]
  referrals                      Referral[]
  clicks                         Click[]
  commissions                    Commission[]
  payouts                        Payout[]
  affiliateShareEvents           AffiliateShareEvent[]
  affiliateDocuments             AffiliateDocument[]
  depositPayments                DepositPayment[]
  serviceFeePayments             ServiceFeePayment[]
  paymentMethods                 PaymentMethod[]
  tradeIns                       TradeIn[]
  dealDocuments                  DealDocument[]
  documentRequests               DocumentRequest[]
  refinanceLeads                 RefinanceLead[]
  insuranceDocRequests           InsuranceDocRequest[]
  depositRequests                DepositRequest[]
  conciergeFeeRequests           ConciergeFeeRequest[]
  refunds                        Refund[]
  adminNotifications             AdminNotification[]
  transactions                   Transaction[]
  chargebacks                    Chargeback[]
  financialAuditLogs             FinancialAuditLog[]
  aiConversations                AiConversation[]
  aiAdminActions                 AiAdminAction[]
  externalPreApprovalSubmissions ExternalPreApprovalSubmission[]
  dealerCoverageGapSignals       DealerCoverageGapSignal[]
  vehicleRequestCases            VehicleRequestCase[]
  sourcedOffers                  SourcedOffer[]
  consentArtifacts               ConsentArtifact[]
  preQualProviderEvents          PreQualProviderEvent[]
  forwardingAuthorizations       ForwardingAuthorization[]
  contractManualReviews          ContractManualReview[]

  @@index([mode])
}

// ============================================
// USERS & IDENTITY
// ============================================

enum UserRole {
  BUYER
  DEALER
  DEALER_USER
  ADMIN
  SUPER_ADMIN
  COMPLIANCE_ADMIN
  AFFILIATE
  AFFILIATE_ONLY
  SYSTEM_AGENT
}

model User {
  id                      String   @id @default(cuid())
  email                   String   @unique
  passwordHash            String   @map("passwordHash")
  role                    UserRole
  is_email_verified       Boolean  @default(false)
  first_name              String?
  last_name               String?
  // MFA fields - mapped to snake_case database columns
  mfa_enrolled            Boolean  @default(false)
  mfa_factor_id           String?
  mfa_secret              String?
  mfa_recovery_codes_hash String?  @db.Text
  force_password_reset    Boolean  @default(false)
  // Supabase Auth migration fields
  auth_user_id            String?  @unique
  session_version         Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  // Relations
  buyerProfile        BuyerProfile?
  dealerProfile       Dealer?
  dealerUser          DealerUser?
  adminProfile        AdminUser?
  affiliateProfile    Affiliate?
  contractOverrides   ContractShieldOverride[]
  shieldNotifications ContractShieldNotification[]
  cmaApprovedReviews  ContractManualReview[] @relation("CmaApprovedBy")
  cmaSecondApprovals  ContractManualReview[] @relation("CmaSecondApprover")
  cmaRevokedReviews   ContractManualReview[] @relation("CmaRevokedBy")

  @@index([email])
  @@index([workspaceId])
  @@index([auth_user_id])
  @@map("User")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model BuyerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  firstName String
  lastName  String
  phone     String? // Made phone optional to fix signup
  address   String
  city      String
  state     String
  zip       String

  employment     String?
  employer       String?
  annualIncome   Float?
  housingStatus  String?
  monthlyHousing Float?

  // Additional fields from migration 03
  dateOfBirth         DateTime? @db.Date
  addressLine2        String?
  postalCode          String?
  country             String?   @default("US")
  employmentStatus    String?
  employerName        String?
  monthlyIncomeCents  Int?
  monthlyHousingCents Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  preQualification     PreQualification?
  externalPreApprovals ExternalPreApproval[]
  preferences          BuyerPreferences?
  shortlists           Shortlist[]
  auctions             Auction[]
  deals                SelectedDeal[]
  pickups              PickupAppointment[]
  referrals            Referral[]
  vehicleRequestCases  VehicleRequestCase[]

  @@index([workspaceId])
}

model Dealer {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  businessName  String
  licenseNumber String @unique
  phone         String
  address       String
  city          String
  state         String
  zip           String

  integrityScore Float   @default(100)
  verified       Boolean @default(false)

  // Additional fields from migration 04
  legalName    String?
  email        String?
  addressLine2 String?
  postalCode   String?
  country      String? @default("US")
  active       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventory             InventoryItem[]
  auctionParticipations AuctionParticipant[]
  contracts             ContractDocument[]
  scans                 ContractShieldScan[]
  pickups               PickupAppointment[]
  dealerUsers           DealerUser[]

  @@index([licenseNumber])
  @@index([workspaceId])
}

model DealerUser {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealerId  String
  dealer    Dealer  @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  roleLabel String?

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dealerId])
  @@index([workspaceId])
  @@map("DealerUser")
}

model AdminUser {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  firstName String
  lastName  String
  role      String @default("ADMIN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model Affiliate {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  referralCode String  @unique
  firstName    String?
  lastName     String?

  totalEarnings   Float @default(0)
  pendingEarnings Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  referrals   Referral[]
  clicks      Click[]
  commissions Commission[]
  payouts     Payout[]

  @@index([referralCode])
  @@index([workspaceId])
}

// ============================================
// SYSTEM 1: PRE-QUALIFICATION
// ============================================

enum CreditTier {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DECLINED
}

enum PreQualSource {
  INTERNAL
  EXTERNAL_MANUAL
  MICROBILT
  IPREDICT
  PROVIDER_BACKED
}

enum ConsentCaptureMethod {
  WEB
  PHONE
  WRITTEN
}

model PreQualification {
  id      String       @id @default(cuid())
  buyerId String       @unique
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  // Status lifecycle: ACTIVE, EXPIRED, REVOKED, FAILED, PENDING
  status String?

  creditScore         Int?
  creditTier          CreditTier
  maxOtd              Float
  estimatedMonthlyMin Float
  estimatedMonthlyMax Float

  // Cents-based equivalents for precise financial calculations
  maxOtdAmountCents      Int?
  minMonthlyPaymentCents Int?
  maxMonthlyPaymentCents Int?

  dti               Float?
  dtiRatio          Float?
  softPullCompleted Boolean   @default(false)
  softPullDate      DateTime?
  consentGiven      Boolean   @default(false)
  consentDate       DateTime?

  // Source discriminator: INTERNAL | EXTERNAL_MANUAL | PROVIDER_BACKED
  source               PreQualSource @default(INTERNAL)
  externalSubmissionId String?

  // Provider display name; for manual approvals: "External Verified: <lenderName>"
  providerName        String?
  providerReferenceId String?
  rawResponseJson     Json?

  // Consent and forwarding authorization artifact references
  consentArtifactId               String?
  consumerAuthorizationArtifactId String?

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  consentArtifact               PrequalConsentArtifact?        @relation(fields: [consentArtifactId], references: [id])
  consumerAuthorizationArtifact ConsumerAuthorizationArtifact? @relation(fields: [consumerAuthorizationArtifactId], references: [id])
  sessions                      PrequalSession[]
  providerEvents                PrequalProviderEvent[]
  offerSnapshots                PrequalOfferSnapshot[]

  @@index([buyerId])
  @@index([workspaceId])
  @@index([externalSubmissionId])
  @@index([consentArtifactId])
}

// Versioned consent text/UX for FCRA and soft-pull flows
model ConsentVersion {
  id String @id @default(cuid())

  version     String    @unique // e.g. "v1.0", "v2.1"
  label       String // Human-readable label, e.g. "Soft Pull Consent v2"
  bodyText    String    @db.Text // Full consent language shown to user
  effectiveAt DateTime
  retiredAt   DateTime?

  createdAt DateTime @default(now())

  // Relations
  consentArtifacts ConsentArtifact[]

  @@index([version])
  @@index([effectiveAt])
}

// Immutable consent artifact — records that a user consented to a specific version
model ConsentArtifact {
  id String @id @default(cuid())

  userId  String
  buyerId String

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  consentVersionId String
  consentVersion   ConsentVersion @relation(fields: [consentVersionId], references: [id])

  consentText  String   @db.Text // Snapshot of text shown at capture time
  consentGiven Boolean  @default(true)
  capturedAt   DateTime @default(now())

  ipAddress String?
  userAgent String?

  // Link to resulting prequal (populated after provider execution)
  preQualificationId String?

  // Immutable — no updatedAt
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([buyerId])
  @@index([consentVersionId])
  @@index([preQualificationId])
  @@index([workspaceId])
}

// Provider event log — replaces raw SQL prequal_provider_events table
model PreQualProviderEvent {
  id String @id @default(cuid())

  userId             String
  preQualificationId String?

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  providerName    String // e.g. "AutoLenisPrequal", "MicroBilt", "iPredict"
  requestPayload  Json
  responsePayload Json?
  status          String // SUCCESS | ERROR | TIMEOUT
  errorMessage    String?

  durationMs Int? // Provider call latency

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([preQualificationId])
  @@index([providerName])
  @@index([createdAt])
  @@index([workspaceId])
}

// Separate forwarding authorization artifact — required before prequal results
// can be shared with dealers or third parties
model ForwardingAuthorization {
  id String @id @default(cuid())

  userId  String
  buyerId String

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  preQualificationId String

  // What was authorized
  authorizedRecipientType String // e.g. "DEALER", "LENDER"
  authorizedRecipientId   String?

  consentText  String   @db.Text // Forwarding-specific consent language
  consentGiven Boolean  @default(true)
  capturedAt   DateTime @default(now())

  ipAddress String?
  userAgent String?

  revokedAt     DateTime?
  revokedReason String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([buyerId])
  @@index([preQualificationId])
  @@index([authorizedRecipientId])
  @@index([workspaceId])
}

// ============================================
// SYSTEM 2: VEHICLE DISCOVERY & SHORTLISTING
// ============================================

model BuyerPreferences {
  id      String       @id @default(cuid())
  buyerId String       @unique
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  makes       String[]
  bodyStyles  String[]
  minYear     Int?
  maxYear     Int?
  maxMileage  Int?
  maxDistance Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

model Vehicle {
  id  String @id @default(cuid())
  vin String @unique

  year      Int
  make      String
  model     String
  trim      String?
  bodyStyle String

  mileage       Int
  exteriorColor String?
  interiorColor String?
  transmission  String?
  fuelType      String?

  // Additional fields from migration 05
  drivetrain    String?
  engine        String?
  colorExterior String?
  colorInterior String?

  images String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventoryItems InventoryItem[]

  @@index([vin])
  @@index([make, model])
}

model InventoryItem {
  id       String @id @default(cuid())
  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  price  Float
  status String @default("AVAILABLE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shortlistItems ShortlistItem[]
  auctionOffers  AuctionOffer[]

  @@index([dealerId])
  @@index([vehicleId])
  @@index([workspaceId])
}

model Shortlist {
  id      String       @id @default(cuid())
  buyerId String
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  name String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  items    ShortlistItem[]
  auctions Auction[]

  @@index([buyerId])
  @@index([workspaceId])
}

model ShortlistItem {
  id          String    @id @default(cuid())
  shortlistId String
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  addedAt DateTime @default(now())

  @@unique([shortlistId, inventoryItemId])
  @@index([shortlistId])
}

// ============================================
// SYSTEM 3: SILENT REVERSE AUCTION
// ============================================

enum AuctionStatus {
  PENDING_DEPOSIT
  ACTIVE
  CLOSED
  COMPLETED
  CANCELLED
}

model Auction {
  id      String       @id @default(cuid())
  buyerId String
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id])

  shortlistId String
  shortlist   Shortlist @relation(fields: [shortlistId], references: [id])

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  status AuctionStatus @default(PENDING_DEPOSIT)

  startsAt DateTime?
  endsAt   DateTime?
  closedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participants     AuctionParticipant[]
  offers           AuctionOffer[]
  bestPriceOptions BestPriceOption[]

  @@index([buyerId])
  @@index([status])
  @@index([workspaceId])
}

model AuctionParticipant {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  dealerId String
  dealer   Dealer @relation(fields: [dealerId], references: [id])

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  invitedAt DateTime  @default(now())
  viewedAt  DateTime?

  @@unique([auctionId, dealerId])
  @@index([auctionId])
  @@index([dealerId])
  @@index([workspaceId])
}

model AuctionOffer {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  participantId String

  inventoryItemId String

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  cashOtd       Float
  taxAmount     Float
  feesBreakdown Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  financingOptions AuctionOfferFinancingOption[]
  inventoryItem    InventoryItem                 @relation(fields: [inventoryItemId], references: [id])
  selectedDeals    SelectedDeal[]

  @@index([auctionId])
  @@index([inventoryItemId])
  @@index([workspaceId])
}

model AuctionOfferFinancingOption {
  id      String       @id @default(cuid())
  offerId String
  offer   AuctionOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  apr            Float
  termMonths     Int
  downPayment    Float
  monthlyPayment Float

  createdAt DateTime @default(now())

  @@index([offerId])
}

// ============================================
// SYSTEM 4: BEST PRICE ENGINE
// ============================================

enum BestPriceType {
  BEST_CASH
  BEST_MONTHLY
  BALANCED
}

model BestPriceOption {
  id        String  @id @default(cuid())
  auctionId String
  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  type BestPriceType

  offerId         String
  inventoryItemId String
  dealerId        String

  cashOtd        Float
  monthlyPayment Float?

  score Float

  createdAt DateTime @default(now())

  @@index([auctionId])
  @@index([type])
  @@index([workspaceId])
}

// ============================================
// SYSTEM 5: FINANCING & SELECTED DEAL
// ============================================

enum DealStatus {
  SELECTED
  FINANCING_PENDING
  FINANCING_APPROVED
  FEE_PENDING
  FEE_PAID
  INSURANCE_PENDING
  INSURANCE_COMPLETE
  CONTRACT_PENDING
  CONTRACT_REVIEW
  CONTRACT_MANUAL_REVIEW_REQUIRED
  CONTRACT_INTERNAL_FIX_IN_PROGRESS
  CONTRACT_ADMIN_OVERRIDE_APPROVED
  CONTRACT_APPROVED
  SIGNING_PENDING
  SIGNED
  PICKUP_SCHEDULED
  COMPLETED
  CANCELLED
}

model SelectedDeal {
  id      String       @id @default(cuid())
  buyerId String
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id])

  auctionId       String?
  offerId         String?
  inventoryItemId String?
  dealerId        String

  // Sourced deal fields (populated for deals originating from sourcing, null for auction deals)
  sourcingCaseId String?
  sourcingCase   VehicleRequestCase? @relation(fields: [sourcingCaseId], references: [id])
  sourcedOfferId String?             @unique
  sourcedOffer   SourcedOffer?       @relation(fields: [sourcedOfferId], references: [id])

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  status DealStatus @default(SELECTED)

  cashOtd       Float
  taxAmount     Float
  feesBreakdown Json

  insurance_status String?
  user_id          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  financingOffer    FinancingOffer?
  serviceFeePayment ServiceFeePayment?
  insurancePolicy   InsurancePolicy?
  contracts         ContractDocument[]
  scan              ContractShieldScan?
  manualReviews     ContractManualReview[]
  eSignEnvelope     ESignEnvelope?
  pickup            PickupAppointment?
  tradeIn           TradeIn? // Added relation to TradeIn
  auctionOffer      AuctionOffer?       @relation(fields: [offerId], references: [id])

  @@index([buyerId])
  @@index([status])
  @@index([workspaceId])
  @@index([sourcingCaseId])
  @@index([sourcedOfferId])
}

model FinancingOffer {
  id     String       @id @default(cuid())
  dealId String       @unique
  deal   SelectedDeal @relation(fields: [dealId], references: [id])

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  lenderName     String
  apr            Float
  termMonths     Int
  downPayment    Float
  monthlyPayment Float
  totalFinanced  Float

  approved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

enum ExternalPreApprovalStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  SUPERSEDED
}

model ExternalPreApproval {
  id      String       @id @default(cuid())
  buyerId String
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  lenderName     String
  approvedAmount Float
  apr            Float?
  termMonths     Int?

  // Document metadata (OWASP-aligned)
  documentUrl      String?
  documentFileName String?
  documentFileSize Int?
  documentMimeType String?

  // Status workflow
  status ExternalPreApprovalStatus @default(SUBMITTED)

  // Review fields
  reviewedBy      String?
  reviewedAt      DateTime?
  rejectionReason String?
  adminNotes      String?

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([workspaceId])
  @@index([status])
}

model ExternalPreApprovalSubmission {
  id      String @id @default(cuid())
  buyerId String

  // Workspace / tenant isolation
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  // Submission metadata
  lenderName             String
  approvedAmount         Float
  maxOtdAmountCents      Int? // normalized OTD in cents
  apr                    Float?
  aprBps                 Int? // APR in basis points
  termMonths             Int?
  minMonthlyPaymentCents Int?
  maxMonthlyPaymentCents Int?
  dtiRatioBps            Int? // DTI ratio in basis points
  expiresAt              DateTime?
  submissionNotes        String? // buyer notes

  // Uploaded document (private storage, random filename — OWASP aligned)
  storageBucket       String?
  documentStoragePath String?
  originalFileName    String?
  fileSizeBytes       Int?
  mimeType            String?
  sha256              String? // file integrity hash

  // Review workflow
  status              ExternalPreApprovalStatus @default(SUBMITTED)
  reviewedBy          String?
  reviewedAt          DateTime?
  decisionAt          DateTime?
  reviewNotes         String? // admin notes
  rejectionReason     String?
  rejectionReasonCode String?
  supersededById      String? // self FK for chain tracking

  // Link to PreQualification created on approval
  preQualificationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId])
  @@index([workspaceId])
  @@index([status])
  @@index([preQualificationId])
}

