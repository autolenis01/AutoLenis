// ============================================
// SYSTEM: PREQUALIFICATION COMPLIANCE
// MicroBilt / Experian / iPredict integration
// ============================================

/// Versioned consent form text. Each version is immutable after creation.
/// The exact web-based UX must be exportable for MicroBilt review/approval.
model PrequalConsentVersion {
  id          String    @id @default(cuid())
  version     String    @unique // e.g. "1.0.0", "1.1.0"
  bodyText    String    @db.Text // Full consent language
  consentText String?   @db.Text // Migration alias — new code reads this; bodyText is the source of truth
  htmlHash    String? // Hash of the HTML consent form rendered to user
  active      Boolean   @default(false) // Whether this version is the current active consent
  effectiveAt DateTime
  retiredAt   DateTime?
  createdBy   String? // admin userId who published this version
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  artifacts PrequalConsentArtifact[]

  @@index([version])
  @@index([effectiveAt])
}

/// Immutable record of consumer's written-instruction consent.
/// Retained for FCRA compliance; linked to the consent version shown.
model PrequalConsentArtifact {
  id               String                @id @default(cuid())
  userId           String
  consentVersionId String
  consentVersion   PrequalConsentVersion @relation(fields: [consentVersionId], references: [id])

  consentText     String                @db.Text // Exact text shown at time of consent
  renderedText    String?               @db.Text // Migration alias — new code writes this; consentText is the source of truth
  htmlHash        String? // Hash of the rendered HTML
  consentGiven    Boolean
  consentDate     DateTime
  captureMethod   ConsentCaptureMethod? @default(WEB) // How consent was captured
  acceptedAt      DateTime?
  ipAddress       String?
  userAgent       String?
  fingerprintHash String? // Optional browser fingerprint

  sessionId              String? // Link to PrequalSession if available
  reproducibleStorageUrl String? // URL to reproducible storage of consent
  retentionLocked        Boolean @default(true) // Whether this artifact is locked for retention

  createdAt DateTime @default(now())

  preQualifications PreQualification[]

  @@index([userId])
  @@index([consentVersionId])
  @@index([sessionId])
}

/// Separate affirmative authorization for forwarding consumer-supplied data
/// to third parties (e.g. lenders). Required before any data forwarding.
model ConsumerAuthorizationArtifact {
  id                   String    @id @default(cuid())
  userId               String
  authorizationType    String // e.g. "DATA_FORWARDING", "THIRD_PARTY_SHARING"
  authorized           Boolean
  authorizationText    String    @db.Text // Exact text shown
  authorizedParties    String[] // List of authorized third-party names
  recipientDescription String? // Who data would be forwarded to
  ipAddress            String?
  userAgent            String?
  authorizedAt         DateTime
  acceptedAt           DateTime?
  retentionLocked      Boolean   @default(true) // Whether this artifact is locked for retention

  sessionId String? // Link to PrequalSession if available

  createdAt DateTime @default(now())

  preQualifications PreQualification[]

  @@index([userId])
  @@index([authorizationType])
  @@index([sessionId])
}

/// Tracks a complete prequalification session lifecycle.
/// Links consent artifacts, provider events, and results.
model PrequalSession {
  id          String  @id @default(cuid())
  userId      String
  workspaceId String?

  status     String @default("INITIATED") // INITIATED, CONSENT_CAPTURED, PROCESSING, COMPLETED, FAILED, EXPIRED
  sourceType String @default("INTERNAL") // INTERNAL, MICROBILT, IPREDICT

  prequalificationId String? // FK to resulting PreQualification (set after completion)

  consentArtifactId         String? // FK to written-instruction consent
  forwardingAuthorizationId String? // FK to forwarding authorization (if applicable)

  ipAddress String?
  userAgent String?
  startedAt DateTime?

  providerRequestedAt DateTime?
  providerRespondedAt DateTime?

  expiresAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  preQualification PreQualification?      @relation(fields: [prequalificationId], references: [id])
  providerEvents   PrequalProviderEvent[]

  @@index([userId])
  @@index([status])
  @@index([workspaceId])
  @@index([prequalificationId])
}

/// Audit-linked record of every provider request/response pair.
/// Stores raw payloads for compliance evidence.
model PrequalProviderEvent {
  id        String         @id @default(cuid())
  sessionId String
  session   PrequalSession @relation(fields: [sessionId], references: [id])

  userId             String
  prequalificationId String?

  providerName        String // "MicroBilt", "iPredict", "AutoLenisPrequal"
  eventType           String // "PREQUALIFY", "RISK_SCORE", "REFRESH"
  requestPayload      Json?
  responsePayload     Json?
  requestPayloadJson  Json? // Migration alias for requestPayload
  responsePayloadJson Json? // Migration alias for responsePayload
  responseStatus      String // "SUCCESS", "ERROR", "TIMEOUT"
  errorMessage        String?
  errorCode           String?
  latencyMs           Int?

  createdAt DateTime @default(now())

  preQualification PreQualification? @relation(fields: [prequalificationId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([providerName])
  @@index([createdAt])
  @@index([prequalificationId])
}

/// Logs the permissible purpose for each credit inquiry.
/// Required for FCRA compliance.
model PermissiblePurposeLog {
  id                 String  @id @default(cuid())
  userId             String
  sessionId          String?
  prequalificationId String?

  permissiblePurpose String // e.g. "WRITTEN_INSTRUCTIONS_OF_CONSUMER"
  purpose            String? // Migration alias for permissiblePurpose
  purposeDescription String  @db.Text
  providerName       String
  provider           String? // Migration alias for providerName
  inquiryType        String // "SOFT_PULL", "HARD_PULL"
  requestReference   String? // External reference/tracking ID
  certifiedBy        String? // System or admin userId

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([permissiblePurpose])
}

/// Snapshot of offers presented to consumer from prequal results.
model PrequalOfferSnapshot {
  id                 String   @id @default(cuid())
  preQualificationId String
  offerJson          Json
  presentedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  preQualification PreQualification @relation(fields: [preQualificationId], references: [id])

  @@index([preQualificationId])
}

// ============================================
// INVENTORY INTELLIGENCE SUBSYSTEM
// ============================================

enum DealerProspectStatus {
  DISCOVERED
  CONTACTED
  RESPONDED
  ONBOARDING
  CONVERTED
  REJECTED
  SUPPRESSED
}

enum DealerSourceType {
  WEBSITE
  FEED
  API
  MANUAL
}

enum DealerSourceStatus {
  ACTIVE
  PAUSED
  ERRORED
  SUPPRESSED
}

enum SourceRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MarketVehicleStatus {
  ACTIVE
  STALE
  SUPPRESSED
  PROMOTED
}

enum VerifiedVehicleStatus {
  AVAILABLE
  HOLD
  SOLD
  REMOVED
}

enum InventoryMatchStatus {
  PENDING
  MATCHED
  INVITED
  OFFER_RECEIVED
  EXPIRED
}

enum CoverageGapStatus {
  OPEN
  INVITE_SENT
  RESOLVED
  DISMISSED
}

enum QuickOfferStatus {
  PENDING
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum IdentityState {
  ANONYMOUS
  CONDITIONAL_HOLD
  RELEASED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum JobType {
  DISCOVER_DEALER
  FETCH_SOURCE
  PARSE_SOURCE
  NORMALIZE_SOURCE
  DEDUPE_INVENTORY
  REFRESH_SOURCE
  STALE_SWEEP
  GENERATE_DEALER_INVITES
  PROCESS_QUICK_OFFER
  PROMOTE_VERIFIED_INVENTORY
  SCAN_CIRCUMVENTION_SIGNALS
}

model DealerProspect {
  id          String  @id @default(cuid())
  workspaceId String?

  businessName String
  phone        String?
  email        String?
  website      String?
  address      String?
  city         String?
  state        String?
  zip          String?

  discoveredFrom String?
  discoveredAt   DateTime @default(now())

  status DealerProspectStatus @default(DISCOVERED)
  notes  String?              @db.Text

  convertedDealerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sources         DealerSource[]
  invites         DealerIntelligenceInvite[]
  quickOffers     DealerQuickOffer[]
  conversions     DealerOnboardingConversion[]
  lifecycleEvents DealerLifecycleEvent[]

  @@index([workspaceId])
  @@index([status])
  @@index([zip])
  @@index([businessName])
  @@index([convertedDealerId])
}

model DealerSource {
  id          String  @id @default(cuid())
  workspaceId String?

  prospectId String?
  prospect   DealerProspect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  dealerId String?

  sourceType DealerSourceType
  sourceUrl  String?
  feedUrl    String?

  status               DealerSourceStatus @default(ACTIVE)
  lastFetchedAt        DateTime?
  fetchIntervalMinutes Int                @default(1440)

  errorCount       Int     @default(0)
  lastErrorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs         DealerSourceRun[]
  rawSnapshots InventoryRawSnapshot[]
  sourceErrors InventorySourceError[]

  @@index([workspaceId])
  @@index([prospectId])
  @@index([dealerId])
  @@index([status])
  @@index([sourceType])
}

model DealerSourceRun {
  id       String       @id @default(cuid())
  sourceId String
  source   DealerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status          SourceRunStatus @default(PENDING)
  startedAt       DateTime?
  completedAt     DateTime?
  vehiclesFound   Int             @default(0)
  vehiclesNew     Int             @default(0)
  vehiclesUpdated Int             @default(0)
  errors          Int             @default(0)
  errorDetails    Json?

  createdAt DateTime @default(now())

  @@index([sourceId])
  @@index([status])
  @@index([createdAt])
}

model InventoryRawSnapshot {
  id       String       @id @default(cuid())
  sourceId String
  source   DealerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  rawData    Json
  fetchedAt  DateTime  @default(now())
  parsedAt   DateTime?
  parseError String?

  createdAt DateTime @default(now())

  sightings InventoryVehicleSighting[]

  @@index([sourceId])
  @@index([fetchedAt])
}

model InventoryVehicleSighting {
  id         String               @id @default(cuid())
  snapshotId String
  snapshot   InventoryRawSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  vin           String?
  year          Int?
  make          String?
  model         String?
  trim          String?
  mileage       Int?
  priceCents    Int?
  exteriorColor String?
  bodyStyle     String?
  stockNumber   String?

  rawJson Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([snapshotId])
  @@index([vin])
  @@index([make, model])
}

model InventoryMarketVehicle {
  id          String  @id @default(cuid())
  workspaceId String?

  dealerSourceId String?
  prospectId     String?

  vin           String?
  year          Int
  make          String
  model         String
  trim          String?
  bodyStyle     String?
  mileage       Int?
  priceCents    Int?
  exteriorColor String?
  interiorColor String?
  transmission  String?
  fuelType      String?
  drivetrain    String?
  engine        String?
  images        String[]
  stockNumber   String?
  dealerName    String?
  dealerZip     String?
  dealerState   String?
  listingUrl    String?

  status      MarketVehicleStatus @default(ACTIVE)
  confidence  Float               @default(0.5)
  firstSeenAt DateTime            @default(now())
  lastSeenAt  DateTime            @default(now())
  staleAfter  DateTime?

  promotedToVerifiedId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory    InventoryPriceHistory[]
  duplicateGroups InventoryDuplicateGroupMember[]
  matches         BuyerRequestInventoryMatch[]

  @@unique([vin, prospectId], name: "market_vin_prospect")
  @@index([workspaceId])
  @@index([status])
  @@index([make, model])
  @@index([dealerZip])
  @@index([vin])
  @@index([prospectId])
  @@index([promotedToVerifiedId])
}

model InventoryVerifiedVehicle {
  id          String  @id @default(cuid())
  workspaceId String?

  dealerId        String
  vehicleId       String?
  inventoryItemId String?

  vin           String
  year          Int
  make          String
  model         String
  trim          String?
  bodyStyle     String?
  mileage       Int?
  priceCents    Int?
  exteriorColor String?
  interiorColor String?
  transmission  String?
  fuelType      String?
  drivetrain    String?
  engine        String?
  images        String[]
  stockNumber   String?
  location      String?
  description   String?  @db.Text

  status VerifiedVehicleStatus @default(AVAILABLE)

  promotedFromMarketVehicleId String?
  promotedAt                  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory    InventoryPriceHistory[]
  duplicateGroups InventoryDuplicateGroupMember[]
  matches         BuyerRequestInventoryMatch[]

  @@unique([vin, dealerId], name: "verified_vin_dealer")
  @@index([workspaceId])
  @@index([dealerId])
  @@index([status])
  @@index([make, model])
  @@index([vin])
  @@index([promotedFromMarketVehicleId])
}

model InventoryPriceHistory {
  id                String                    @id @default(cuid())
  marketVehicleId   String?
  marketVehicle     InventoryMarketVehicle?   @relation(fields: [marketVehicleId], references: [id], onDelete: Cascade)
  verifiedVehicleId String?
  verifiedVehicle   InventoryVerifiedVehicle? @relation(fields: [verifiedVehicleId], references: [id], onDelete: Cascade)

  priceCents Int
  recordedAt DateTime @default(now())

  @@index([marketVehicleId])
  @@index([verifiedVehicleId])
  @@index([recordedAt])
}

model InventoryDuplicateGroup {
  id          String  @id @default(cuid())
  workspaceId String?

  vin        String?
  status     String    @default("pending")
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members InventoryDuplicateGroupMember[]

  @@index([workspaceId])
  @@index([vin])
  @@index([status])
}

model InventoryDuplicateGroupMember {
  id      String                  @id @default(cuid())
  groupId String
  group   InventoryDuplicateGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  marketVehicleId   String?
  marketVehicle     InventoryMarketVehicle?   @relation(fields: [marketVehicleId], references: [id], onDelete: SetNull)
  verifiedVehicleId String?
  verifiedVehicle   InventoryVerifiedVehicle? @relation(fields: [verifiedVehicleId], references: [id], onDelete: SetNull)

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([marketVehicleId])
  @@index([verifiedVehicleId])
}

model InventorySourceError {
  id       String       @id @default(cuid())
  sourceId String
  source   DealerSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  errorType    String
  errorMessage String   @db.Text
  rawPayload   Json?
  occurredAt   DateTime @default(now())

  @@index([sourceId])
  @@index([errorType])
  @@index([occurredAt])
}

model BuyerRequestInventoryMatch {
  id          String  @id @default(cuid())
  workspaceId String?

  buyerRequestId String?

  marketVehicleId   String?
  marketVehicle     InventoryMarketVehicle?   @relation(fields: [marketVehicleId], references: [id], onDelete: SetNull)
  verifiedVehicleId String?
  verifiedVehicle   InventoryVerifiedVehicle? @relation(fields: [verifiedVehicleId], references: [id], onDelete: SetNull)

  coverageType String?
  matchScore   Float                @default(0)
  status       InventoryMatchStatus @default(PENDING)

  auctionInvitationId String?
  dealerInviteId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([buyerRequestId])
  @@index([marketVehicleId])
  @@index([verifiedVehicleId])
  @@index([status])
}

model CoverageGapTask {
  id          String  @id @default(cuid())
  workspaceId String?

  buyerRequestId String?
  marketZip      String
  radiusMiles    Int     @default(50)
  make           String?
  model          String?
  yearMin        Int?
  yearMax        Int?

  status     CoverageGapStatus @default(OPEN)
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@index([marketZip])
  @@index([buyerRequestId])
}

model DealerIntelligenceInvite {
  id          String  @id @default(cuid())
  workspaceId String?

  prospectId String?
  prospect   DealerProspect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  dealerId   String?

  buyerRequestId    String?
  coverageGapTaskId String?

  tokenHash      String   @unique
  tokenExpiresAt DateTime
  dealerEmail    String?
  dealerName     String?
  dealerPhone    String?

  status      String    @default("sent")
  sentAt      DateTime  @default(now())
  viewedAt    DateTime?
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quickOffers DealerQuickOffer[]

  @@index([workspaceId])
  @@index([prospectId])
  @@index([dealerId])
  @@index([tokenHash])
  @@index([status])
  @@index([buyerRequestId])
}

model DealerQuickOffer {
  id          String  @id @default(cuid())
  workspaceId String?

  inviteId String
  invite   DealerIntelligenceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  prospectId String?
  prospect   DealerProspect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  vin            String?
  year           Int?
  make           String?
  model          String?
  trim           String?
  mileage        Int?
  priceCents     Int?
  conditionNotes String?   @db.Text
  availableDate  DateTime?
  notes          String?   @db.Text

  status     QuickOfferStatus @default(PENDING)
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([inviteId])
  @@index([prospectId])
  @@index([status])
}

model DealerOnboardingConversion {
  id          String  @id @default(cuid())
  workspaceId String?

  prospectId String
  prospect   DealerProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  dealerId     String?
  quickOfferId String?

  status      String    @default("pending")
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  businessDocsUploaded Boolean @default(false)
  agreementAccepted    Boolean @default(false)
  operationalSetup     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([prospectId])
  @@index([dealerId])
  @@index([status])
}

model MaskedPartyProfile {
  id          String  @id @default(cuid())
  workspaceId String?

  dealId     String?
  buyerId    String?
  dealerId   String?
  prospectId String?

  partyType   String
  maskedId    String  @unique @default(cuid())
  displayName String?

  readinessPayload Json?

  identityState IdentityState @default(ANONYMOUS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([dealId])
  @@index([buyerId])
  @@index([dealerId])
  @@index([maskedId])
  @@index([identityState])
}

model IdentityReleaseEvent {
  id          String  @id @default(cuid())
  workspaceId String?

  dealId   String
  buyerId  String?
  dealerId String?

  previousState IdentityState
  newState      IdentityState
  reason        String?
  triggeredBy   String?

  releasedAt DateTime @default(now())

  @@index([workspaceId])
  @@index([dealId])
  @@index([buyerId])
  @@index([dealerId])
  @@index([releasedAt])
}

model CircumventionAlert {
  id          String  @id @default(cuid())
  workspaceId String?

  dealId    String?
  buyerId   String?
  dealerId  String?
  messageId String?

  alertType String
  severity  AlertSeverity @default(MEDIUM)
  status    AlertStatus   @default(OPEN)

  description String?   @db.Text
  evidence    Json?
  resolvedBy  String?
  resolvedAt  DateTime?
  resolution  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([dealId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

model DealProtectionEvent {
  id          String  @id @default(cuid())
  workspaceId String?

  dealId      String
  eventType   String
  description String? @db.Text
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([dealId])
  @@index([eventType])
  @@index([createdAt])
}

model MessageRedactionEvent {
  id          String  @id @default(cuid())
  workspaceId String?

  messageId   String?
  dealId      String?
  senderId    String?
  recipientId String?

  originalContent String? @db.Text
  redactedContent String? @db.Text
  redactionType   String
  patternsFound   Json?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([messageId])
  @@index([dealId])
  @@index([senderId])
  @@index([createdAt])
}

model DealerLifecycleEvent {
  id          String  @id @default(cuid())
  workspaceId String?

  prospectId String?
  prospect   DealerProspect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  dealerId   String?

  eventType   String
  fromStatus  String?
  toStatus    String?
  metadata    Json?
  performedBy String?

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([prospectId])
  @@index([dealerId])
  @@index([eventType])
  @@index([createdAt])
}

model InventoryIntelligenceJob {
  id          String  @id @default(cuid())
  workspaceId String?

  jobType        JobType
  status         JobStatus @default(PENDING)
  payload        Json?
  result         Json?
  errorMessage   String?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  scheduledAt    DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  deadLetteredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([jobType])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// SYSTEM 1 — Decision Engine Audit Log
// ---------------------------------------------------------------------------

model DecisionAuditLog {
  id              String  @id @default(cuid())
  workspaceId     String?

  entityType      String  // BUYER, DEALER, DEAL
  entityId        String
  correlationId   String
  actorId         String?
  actorType       String? // BUYER, DEALER, ADMIN, SYSTEM

  inputBasis      Json    // Snapshot of decision inputs
  outputResult    Json    // Canonical decision output
  reasonCodes     String[]
  resolvedAt      DateTime

  createdAt       DateTime @default(now())

  @@map("platform_decisions")
  @@index([workspaceId])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([actorId])
  @@index([resolvedAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// SYSTEM 2 — Platform Event Ledger
// ---------------------------------------------------------------------------

model PlatformEvent {
  id               String  @id @default(cuid())

  eventType        String
  eventVersion     Int     @default(1)
  entityType       String
  entityId         String
  parentEntityId   String?
  workspaceId      String?

  actorId          String
  actorType        String
  sourceModule     String
  correlationId    String
  idempotencyKey   String?   @unique
  payload          Json      @default("{}")
  processingStatus String    @default("RECORDED")

  createdAt        DateTime  @default(now())

  @@map("platform_events")
  @@index([eventType])
  @@index([entityType, entityId])
  @@index([parentEntityId])
  @@index([workspaceId])
  @@index([actorId])
  @@index([correlationId])
  @@index([processingStatus])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// SYSTEM 3 — Document Trust Infrastructure
// ---------------------------------------------------------------------------

enum DocumentTrustStatusEnum {
  UPLOADED
  SCANNED
  VERIFIED
  APPROVED
  LOCKED
  SUPERSEDED
  REVOKED
  EXPIRED
}

enum IdentityTrustStatusEnum {
  UNVERIFIED
  PENDING_VERIFICATION
  VERIFIED
  FAILED
  SUSPENDED
  REVOKED
}

model DocumentTrustRecord {
  id                    String  @id @default(cuid())

  ownerEntityId         String
  ownerEntityType       String  // BUYER, DEALER, ADMIN, AFFILIATE, DEAL
  documentType          String  // CONTRACT, EXTERNAL_PREAPPROVAL, CMA_EVIDENCE, etc.
  storageSource         String
  storageReference      String
  uploadTimestamp        DateTime @default(now())
  uploaderId            String
  fileHash              String
  versionNumber         Int     @default(1)
  status                DocumentTrustStatusEnum @default(UPLOADED)
  verificationMetadata  Json?
  verifierId            String?
  verifiedAt            DateTime?
  supersededById        String?
  revocationReason      String?
  revokedAt             DateTime?
  revokedById           String?
  activeForDecision     Boolean @default(true)
  accessScope           String  @default("DEAL_PARTIES")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("trusted_documents")
  @@index([ownerEntityId, ownerEntityType])
  @@index([documentType])
  @@index([status])
  @@index([activeForDecision])
  @@index([fileHash])
  @@index([uploaderId])
  @@index([createdAt])
}

model IdentityTrustRecord {
  id                  String  @id @default(cuid())

  entityId            String
  entityType          String  // BUYER, DEALER, ADMIN, AFFILIATE
  status              IdentityTrustStatusEnum @default(UNVERIFIED)
  verificationSource  String? // MANUAL_ADMIN, KYC_PROVIDER, KYB_PROVIDER, etc.
  verifiedAt          DateTime?
  verifierId          String?
  trustFlags          String[]
  riskFlags           String[]
  manualReviewRequired Boolean @default(false)
  kycStatus           String?
  kybStatus           String?
  lastAssessedAt      DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("identity_trust_records")
  @@unique([entityId, entityType])
  @@index([status])
  @@index([entityType])
  @@index([manualReviewRequired])
  @@index([lastAssessedAt])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// MESSAGING — Threads & Messages
// ---------------------------------------------------------------------------

model MessageThread {
  id          String  @id @default(cuid())
  workspaceId String?

  buyerId  String
  dealerId String

  requestId String?
  dealId    String?

  approvalType     String  @default("autolenis")
  identityReleased Boolean @default(false)
  status           String  @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([workspaceId])
  @@index([buyerId])
  @@index([dealerId])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id       String @id @default(cuid())
  threadId String
  thread   MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  senderType String // BUYER, DEALER, SYSTEM
  senderId   String

  body                 String  @db.Text
  redactedBody         String? @db.Text
  containsSensitiveData Boolean @default(false)
  circumventionScore   Int     @default(0)

  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// AUCTION — Offer Decisions
// ---------------------------------------------------------------------------

model AuctionOfferDecision {
  id        String @id @default(cuid())
  auctionId String
  offerId   String
  buyerId   String

  decision   String // ACCEPTED, DECLINED
  acceptedAt DateTime?
  declinedAt DateTime?

  createdAt DateTime @default(now())

  @@index([auctionId])
  @@index([offerId])
  @@index([buyerId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// INVENTORY — Import Jobs
// ---------------------------------------------------------------------------

model InventoryImportJob {
  id       String @id @default(cuid())
  dealerId String

  status    String @default("PENDING")
  totalRows Int    @default(0)

  createdCount Int @default(0)
  updatedCount Int @default(0)
  failedCount  Int @default(0)

  errorsJson Json?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealerId])
  @@index([status])
  @@index([createdAt])
}
