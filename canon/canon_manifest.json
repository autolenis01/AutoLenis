    "ownerTeam": "platform-engineering",
    "triggerEvents": [
      "Fee structure changes in lib/constants.ts",
      "Commission rate changes in lib/constants.ts",
      "Credit tier threshold changes",
      "Contract Shield threshold changes",
      "New role or permission additions",
      "Legal or compliance policy updates",
      "New platform features launched"
    ],
    "validationChecks": [
      "All fee amounts match lib/constants.ts FEE_STRUCTURE values",
      "All commission rates match lib/constants.ts COMMISSION_RATES values",
      "Credit tier ranges match lib/constants.ts CREDIT_TIERS values",
      "Contract Shield thresholds match lib/constants.ts CONTRACT_SHIELD_THRESHOLDS values",
      "Deposit amount matches lib/constants.ts DEPOSIT_AMOUNT value",
      "Auction duration matches lib/constants.ts AUCTION_DURATION_HOURS value",
      "Pre-qual expiry matches lib/constants.ts PREQUAL_EXPIRY_DAYS value",
      "Max shortlist matches lib/constants.ts MAX_SHORTLIST_ITEMS value"
    ]
  }
